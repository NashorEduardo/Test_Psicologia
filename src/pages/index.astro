---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ITEMS, LIKERT_OPTIONS, UNASSIGNED_ITEMS } from "../lib/items";

const totalItems = ITEMS.length;
---

<BaseLayout title="EPIPP — Escala de Estilos Parentales e Inconsistencia Parental Percibida">
  <div class="app">
    <!-- ============================== HEADER ============================== -->
    <header class="topbar">
      <div class="topbar__inner">
        <span class="brand">EPIPP</span>
        <span class="brand__sub">Estilos Parentales e Inconsistencia Parental Percibida</span>
      </div>
    </header>

    <!-- ============================== INTRO ================================ -->
    <section id="panel-intro" class="panel panel--intro" data-panel>
      <div class="intro__hero">
        <p class="eyebrow">De la Iglesia, Ongarato y Fernández (2011)</p>
        <h1>Escala de Estilos Parentales<br />e Inconsistencia Parental Percibida</h1>
        <p class="intro__lead">
          Este instrumento autoaplicado identifica el estilo de crianza percibido por el participante,
          a partir de dos dimensiones: <strong>respuesta</strong> (afecto, diálogo e indiferencia) y
          <strong>demanda</strong> (coerción verbal, coerción física y prohibiciones).
        </p>

        <dl class="fact-grid">
          <div><dt>Ítems</dt><dd>{totalItems}</dd></div>
          <div><dt>Duración</dt><dd>10–30 min</dd></div>
          <div><dt>Aplicación</dt><dd>Individual o grupal</dd></div>
          <div><dt>Población</dt><dd>Adolescentes y adultos jóvenes</dd></div>
        </dl>

        <div class="notice">
          <strong>Nota metodológica.</strong> Esta aplicación usa marcadores genéricos para el texto
          de los 24 ítems ("Ítem 1", "Ítem 2"...), ya que la redacción original no estaba disponible
          al construir esta herramienta. Sustitúyela por el enunciado real de la escala antes de
          aplicarla a participantes. El ítem <strong>{UNASSIGNED_ITEMS.join(", ")}</strong> no tiene
          subescala asignada en la ficha técnica original — revisa esto contra el artículo fuente.
        </div>

        <button class="btn btn--primary" id="btn-start" type="button">Comenzar la escala</button>
      </div>
    </section>

    <!-- ============================== CUESTIONARIO ========================= -->
    <section id="panel-quiz" class="panel panel--quiz" data-panel hidden>
      <div class="quiz__progress-wrap" aria-hidden="true">
        <div class="quiz__progress-track">
          <div class="quiz__progress-fill" id="progress-fill"></div>
        </div>
        <span class="quiz__progress-label" id="progress-label">Ítem 1 de {totalItems}</span>
      </div>

      <form id="quiz-form" novalidate>
        <div class="quiz__items" id="quiz-items">
          {ITEMS.map((item) => (
            <fieldset class="item-card" data-item={item.number} hidden>
              <legend class="item-card__legend">
                <span class="item-card__number">{String(item.number).padStart(2, "0")}</span>
                <span class="item-card__text">{item.text}</span>
              </legend>
              <div class="item-card__options" role="radiogroup">
                {LIKERT_OPTIONS.map((opt) => (
                  <label class="option">
                    <input type="radio" name={`item-${item.number}`} value={opt.value} required />
                    <span class="option__chip">{opt.label}</span>
                  </label>
                ))}
              </div>
            </fieldset>
          ))}
        </div>

        <div class="quiz__nav">
          <button class="btn btn--ghost" id="btn-prev" type="button">Anterior</button>
          <button class="btn btn--primary" id="btn-next" type="button">Siguiente</button>
          <button class="btn btn--primary" id="btn-submit" type="submit" hidden>Ver resultado</button>
        </div>
      </form>
    </section>

    <!-- ============================== RESULTADO ============================ -->
    <section id="panel-result" class="panel panel--result" data-panel hidden>
      <div class="result__header">
        <p class="eyebrow">Resultado</p>
        <h2 id="result-style">—</h2>
        <p class="result__desc" id="result-style-desc"></p>
      </div>

      <div class="result__grid">
        <div class="result-card">
          <h3>Respuesta</h3>
          <div class="result-card__bar-track">
            <div class="result-card__bar-fill" id="bar-respuesta"></div>
          </div>
          <p class="result-card__level" id="level-respuesta">—</p>
          <p class="result-card__hint">Afecto, diálogo e indiferencia (invertida)</p>
        </div>
        <div class="result-card">
          <h3>Demanda</h3>
          <div class="result-card__bar-track">
            <div class="result-card__bar-fill result-card__bar-fill--clay" id="bar-demanda"></div>
          </div>
          <p class="result-card__level" id="level-demanda">—</p>
          <p class="result-card__hint">Coerción verbal, coerción física y prohibiciones</p>
        </div>
      </div>

      <!-- Plano cartesiano: signature element -->
      <div class="plane-wrap">
        <h3>Ubicación en el plano respuesta–demanda</h3>
        <svg id="plane-svg" viewBox="0 0 320 320" role="img" aria-labelledby="plane-title">
          <title id="plane-title">Plano cartesiano de respuesta y demanda</title>
          <!-- cuadrantes -->
          <rect x="20" y="20" width="140" height="140" class="plane-quad plane-quad--permisivo" />
          <rect x="160" y="20" width="140" height="140" class="plane-quad plane-quad--sobreprotector" />
          <rect x="20" y="160" width="140" height="140" class="plane-quad plane-quad--negligente" />
          <rect x="160" y="160" width="140" height="140" class="plane-quad plane-quad--autoritario" />
          <!-- zona media (autoritativo) -->
          <rect x="110" y="110" width="100" height="100" class="plane-quad plane-quad--autoritativo" />
          <!-- ejes -->
          <line x1="20" y1="160" x2="300" y2="160" class="plane-axis" />
          <line x1="160" y1="20" x2="160" y2="300" class="plane-axis" />
          <!-- punto del participante -->
          <circle id="plane-point" cx="160" cy="160" r="9" class="plane-point" />
          <!-- labels -->
          <text x="160" y="14" class="plane-label" text-anchor="middle">Alta respuesta</text>
          <text x="160" y="312" class="plane-label" text-anchor="middle">Baja respuesta</text>
          <text x="10" y="170" class="plane-label" text-anchor="middle" transform="rotate(-90 10 170)">Baja demanda</text>
          <text x="310" y="170" class="plane-label" text-anchor="middle" transform="rotate(-90 310 170)">Alta demanda</text>
        </svg>
      </div>

      <div class="result__subscales">
        <h3>Detalle por subescala</h3>
        <ul id="subscale-list" class="subscale-list"></ul>
      </div>

      <div class="notice notice--small">
        <strong>Sobre la equivalencia de puntajes.</strong> Los puntos de corte (percentiles 25/75)
        de la ficha técnica original están expresados en una métrica distinta a la escala Likert 1–4
        usada aquí. Esta app traduce el promedio de cada dimensión a su <em>posición relativa</em>
        dentro del rango Likert posible, y compara esa posición contra la posición relativa de los
        cortes originales. Es una equivalencia proporcional declarada, útil con fines formativos —no
        un baremo validado estadísticamente. Verifica contra la tabla de percentiles completa del
        artículo original si necesitas resultados con validez psicométrica plena.
      </div>

      <div class="result__actions">
        <button class="btn btn--ghost" id="btn-restart" type="button">Volver a realizar la escala</button>
      </div>
    </section>

    <footer class="footer">
      <p>
        Basado en: De la Iglesia, G., Ongarato, P. y Fernández Liporace, M. (2011). Propiedades
        psicométricas de una escala de estilos parentales e inconsistencia parental percibida
        (EPIPP). <em>Evaluar, 10</em>, 32–52. Ficha técnica: Raibelis Lugo, Universidad Yacambú (2020).
      </p>
    </footer>
  </div>

  <script>
    import { calcularResultado, type Respuestas } from "../lib/scoring";
    import { ESTILOS_INFO } from "../lib/baremos";
    import { ITEMS as ITEMS_DATA } from "../lib/items";

    const totalItems = ITEMS_DATA.length;
    let currentIndex = 0;
    const respuestas: Respuestas = {};

    const panelIntro = document.getElementById("panel-intro")!;
    const panelQuiz = document.getElementById("panel-quiz")!;
    const panelResult = document.getElementById("panel-result")!;

    const btnStart = document.getElementById("btn-start")!;
    const btnPrev = document.getElementById("btn-prev") as HTMLButtonElement;
    const btnNext = document.getElementById("btn-next") as HTMLButtonElement;
    const btnSubmit = document.getElementById("btn-submit") as HTMLButtonElement;
    const btnRestart = document.getElementById("btn-restart")!;

    const progressFill = document.getElementById("progress-fill")!;
    const progressLabel = document.getElementById("progress-label")!;

    const itemCards = Array.from(document.querySelectorAll<HTMLFieldSetElement>("[data-item]"));

    function showPanel(panel: HTMLElement) {
      [panelIntro, panelQuiz, panelResult].forEach((p) => {
        p.hidden = p !== panel;
      });
      panel.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    function renderItem(index: number) {
      itemCards.forEach((card, i) => {
        card.hidden = i !== index;
      });
      const itemNumber = index + 1;
      progressLabel.textContent = `Ítem ${itemNumber} de ${totalItems}`;
      progressFill.style.width = `${(itemNumber / totalItems) * 100}%`;

      btnPrev.disabled = index === 0;
      const isLast = index === totalItems - 1;
      btnNext.hidden = isLast;
      btnSubmit.hidden = !isLast;
    }

    function currentItemAnswered(): boolean {
      const itemNumber = currentIndex + 1;
      const checked = document.querySelector<HTMLInputElement>(
        `input[name="item-${itemNumber}"]:checked`
      );
      return !!checked;
    }

    function persistCurrentAnswer() {
      const itemNumber = currentIndex + 1;
      const checked = document.querySelector<HTMLInputElement>(
        `input[name="item-${itemNumber}"]:checked`
      );
      if (checked) {
        respuestas[itemNumber] = Number(checked.value);
      }
    }

    btnStart.addEventListener("click", () => {
      showPanel(panelQuiz);
      renderItem(0);
    });

    btnNext.addEventListener("click", () => {
      if (!currentItemAnswered()) {
        itemCards[currentIndex].classList.add("item-card--shake");
        setTimeout(() => itemCards[currentIndex].classList.remove("item-card--shake"), 400);
        return;
      }
      persistCurrentAnswer();
      currentIndex = Math.min(currentIndex + 1, totalItems - 1);
      renderItem(currentIndex);
    });

    btnPrev.addEventListener("click", () => {
      persistCurrentAnswer();
      currentIndex = Math.max(currentIndex - 1, 0);
      renderItem(currentIndex);
    });

    document.getElementById("quiz-form")!.addEventListener("submit", (e) => {
      e.preventDefault();
      if (!currentItemAnswered()) {
        itemCards[currentIndex].classList.add("item-card--shake");
        setTimeout(() => itemCards[currentIndex].classList.remove("item-card--shake"), 400);
        return;
      }
      persistCurrentAnswer();

      const resultado = calcularResultado(respuestas);
      renderResultado(resultado);
      showPanel(panelResult);
    });

    btnRestart.addEventListener("click", () => {
      Object.keys(respuestas).forEach((k) => delete respuestas[Number(k)]);
      document.querySelectorAll<HTMLInputElement>('input[type="radio"]').forEach((el) => {
        el.checked = false;
      });
      currentIndex = 0;
      renderItem(0);
      showPanel(panelIntro);
    });

    function renderResultado(resultado: ReturnType<typeof calcularResultado>) {
      const estiloInfo = ESTILOS_INFO[resultado.estilo];
      (document.getElementById("result-style") as HTMLElement).textContent = estiloInfo.label;
      (document.getElementById("result-style-desc") as HTMLElement).textContent = estiloInfo.descripcion;

      const nivelLabel: Record<string, string> = { bajo: "Bajo", medio: "Medio", alto: "Alto" };

      (document.getElementById("level-respuesta") as HTMLElement).textContent =
        `${nivelLabel[resultado.respuesta.nivel]} · promedio ${resultado.respuesta.promedio.toFixed(2)} / 4`;
      (document.getElementById("level-demanda") as HTMLElement).textContent =
        `${nivelLabel[resultado.demanda.nivel]} · promedio ${resultado.demanda.promedio.toFixed(2)} / 4`;

      (document.getElementById("bar-respuesta") as HTMLElement).style.width =
        `${resultado.respuesta.porcentaje}%`;
      (document.getElementById("bar-demanda") as HTMLElement).style.width =
        `${resultado.demanda.porcentaje}%`;

      // Punto en el plano: x = demanda (baja->alta), y = respuesta (alta arriba -> baja abajo)
      const margin = 20;
      const size = 280; // 300 - margin
      const x = margin + (resultado.demanda.porcentaje / 100) * size;
      const y = margin + ((100 - resultado.respuesta.porcentaje) / 100) * size;
      const point = document.getElementById("plane-point")!;
      point.setAttribute("cx", String(x));
      point.setAttribute("cy", String(y));

      const list = document.getElementById("subscale-list")!;
      list.innerHTML = "";
      resultado.subescalas.forEach((s) => {
        const li = document.createElement("li");
        li.innerHTML = `
          <span class="subscale-list__name">${s.label}</span>
          <span class="subscale-list__value">${s.promedio.toFixed(2)} / 4</span>
          <span class="subscale-list__meta">${s.itemsRespondidos}/${s.itemsEsperados} ítems</span>
        `;
        list.appendChild(li);
      });
    }
  </script>
</BaseLayout>

<style>
  .app {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 20px 80px;
  }

  /* -------------------------------- TOPBAR -------------------------------- */
  .topbar {
    padding: 28px 0 0;
  }
  .topbar__inner {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }
  .brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
    letter-spacing: 0.04em;
    color: var(--color-sage-dark);
  }
  .brand__sub {
    font-size: 0.85rem;
    color: var(--color-ink-soft);
  }

  /* -------------------------------- COMMON -------------------------------- */
  .panel {
    margin-top: 40px;
  }
  .eyebrow {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-sage-dark);
    font-weight: 600;
    margin: 0 0 10px;
  }
  h1 {
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    font-weight: 600;
    margin-bottom: 18px;
  }
  h2 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
  }
  h3 {
    font-size: 1.1rem;
    font-weight: 600;
  }

  .btn {
    border: none;
    border-radius: 999px;
    padding: 14px 28px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }
  .btn--primary {
    background: var(--color-sage-dark);
    color: #fff;
    box-shadow: var(--shadow-soft);
  }
  .btn--primary:hover {
    background: var(--color-sage);
    transform: translateY(-1px);
  }
  .btn--primary:disabled {
    background: #b9c2ba;
    cursor: not-allowed;
    transform: none;
  }
  .btn--ghost {
    background: transparent;
    color: var(--color-ink-soft);
    border: 1.5px solid var(--color-line);
  }
  .btn--ghost:hover {
    border-color: var(--color-sage);
    color: var(--color-sage-dark);
  }
  .btn--ghost:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .notice {
    background: var(--color-warn-bg);
    border: 1px solid var(--color-warn-border);
    border-radius: var(--radius);
    padding: 16px 18px;
    font-size: 0.88rem;
    color: var(--color-ink-soft);
    margin: 28px 0;
  }
  .notice strong {
    color: var(--color-ink);
  }
  .notice--small {
    font-size: 0.82rem;
  }

  /* -------------------------------- INTRO ---------------------------------- */
  .intro__lead {
    font-size: 1.05rem;
    color: var(--color-ink-soft);
    max-width: 540px;
  }

  .fact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin: 32px 0 0;
    padding: 0;
  }
  .fact-grid > div {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    padding: 16px 18px;
  }
  .fact-grid dt {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-ink-soft);
    margin: 0 0 4px;
  }
  .fact-grid dd {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
  }

  /* -------------------------------- QUIZ ------------------------------------ */
  .quiz__progress-wrap {
    margin-bottom: 28px;
  }
  .quiz__progress-track {
    height: 6px;
    background: var(--color-line);
    border-radius: 999px;
    overflow: hidden;
  }
  .quiz__progress-fill {
    height: 100%;
    background: var(--color-sage);
    width: 4.16%;
    transition: width 0.35s ease;
  }
  .quiz__progress-label {
    display: block;
    margin-top: 8px;
    font-size: 0.82rem;
    color: var(--color-ink-soft);
  }

  .item-card {
    border: none;
    margin: 0;
    padding: 0;
    background: var(--color-paper);
    border-radius: 20px;
    box-shadow: var(--shadow-card);
    padding: 32px 28px;
    animation: fade-in 0.3s ease;
  }
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .item-card--shake {
    animation: shake 0.4s ease;
  }
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    75% { transform: translateX(6px); }
  }

  .item-card__legend {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 0 0 22px;
    margin-bottom: 22px;
    border-bottom: 1px solid var(--color-line);
    width: 100%;
  }
  .item-card__number {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--color-clay);
    flex-shrink: 0;
  }
  .item-card__text {
    font-size: 1.15rem;
    line-height: 1.4;
  }

  .item-card__options {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
  .option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .option__chip {
    display: block;
    text-align: center;
    padding: 14px 10px;
    border: 1.5px solid var(--color-line);
    border-radius: 12px;
    cursor: pointer;
    font-size: 0.92rem;
    font-weight: 500;
    transition: all 0.15s ease;
  }
  .option input:checked + .option__chip {
    background: var(--color-sage-dark);
    border-color: var(--color-sage-dark);
    color: #fff;
  }
  .option input:focus-visible + .option__chip {
    outline: 3px solid var(--color-sage);
    outline-offset: 2px;
  }
  .option:hover .option__chip {
    border-color: var(--color-sage);
  }

  .quiz__nav {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    margin-top: 24px;
  }
  .quiz__nav .btn {
    flex: 1;
  }

  /* -------------------------------- RESULT ---------------------------------- */
  .result__header {
    text-align: center;
    margin-bottom: 32px;
  }
  .result__desc {
    color: var(--color-ink-soft);
    max-width: 480px;
    margin: 10px auto 0;
  }

  .result__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 36px;
  }
  .result-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    padding: 20px;
  }
  .result-card__bar-track {
    height: 10px;
    border-radius: 999px;
    background: var(--color-line);
    margin: 12px 0 10px;
    overflow: hidden;
  }
  .result-card__bar-fill {
    height: 100%;
    background: var(--color-sage);
    width: 0%;
    transition: width 0.6s ease;
  }
  .result-card__bar-fill--clay {
    background: var(--color-clay);
  }
  .result-card__level {
    font-weight: 600;
    margin: 0;
  }
  .result-card__hint {
    font-size: 0.8rem;
    color: var(--color-ink-soft);
    margin: 4px 0 0;
  }

  .plane-wrap {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 36px;
    text-align: center;
  }
  .plane-wrap h3 {
    margin-bottom: 16px;
  }
  #plane-svg {
    width: 100%;
    max-width: 320px;
    height: auto;
  }
  .plane-quad {
    fill-opacity: 0.5;
  }
  .plane-quad--permisivo { fill: #d9e3da; }
  .plane-quad--sobreprotector { fill: var(--color-clay-soft); }
  .plane-quad--negligente { fill: #e6e2d6; }
  .plane-quad--autoritario { fill: #ead9cc; }
  .plane-quad--autoritativo { fill: var(--color-paper); fill-opacity: 0.9; stroke: var(--color-sage); stroke-width: 1; stroke-dasharray: 4 3; }
  .plane-axis {
    stroke: var(--color-ink-soft);
    stroke-width: 1.5;
  }
  .plane-point {
    fill: var(--color-clay);
    stroke: #fff;
    stroke-width: 3;
    transition: cx 0.6s ease, cy 0.6s ease;
  }
  .plane-label {
    font-size: 9px;
    fill: var(--color-ink-soft);
    font-family: var(--font-body);
  }

  .result__subscales {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 24px;
  }
  .subscale-list {
    list-style: none;
    margin: 16px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .subscale-list li {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid var(--color-line);
    font-size: 0.92rem;
  }
  .subscale-list li:last-child {
    border-bottom: none;
  }
  .subscale-list__name {
    font-weight: 500;
  }
  .subscale-list__value {
    font-weight: 600;
    color: var(--color-sage-dark);
  }
  .subscale-list__meta {
    font-size: 0.78rem;
    color: var(--color-ink-soft);
  }

  .result__actions {
    text-align: center;
    margin-top: 32px;
  }

  /* -------------------------------- FOOTER ---------------------------------- */
  .footer {
    margin-top: 60px;
